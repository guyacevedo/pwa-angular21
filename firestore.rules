rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============= FUNCIONES AUXILIARES =============

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // Roles con acceso completo de gestión
    function isAdmin() {
      return isAuthenticated() &&
             userRole() in ['PROPIETARIO', 'ADMINISTRADOR', 'ADMIN_TI'];
    }

    // Roles con acceso comercial (ventas, compras, contactos)
    function canManageComercio() {
      return isAuthenticated() &&
             userRole() in ['PROPIETARIO', 'ADMINISTRADOR', 'SECRETARIO'];
    }

    // Roles con acceso a inventario y bodega
    function canManageBodega() {
      return isAuthenticated() &&
             userRole() in ['PROPIETARIO', 'ADMINISTRADOR', 'BODEGA'];
    }

    // Roles con acceso a logística (viajes, camiones)
    function canManageLogistica() {
      return isAuthenticated() &&
             userRole() in ['PROPIETARIO', 'ADMINISTRADOR', 'CHOFER'];
    }

    // Lectura general (todos los autenticados pueden leer datos del negocio)
    function canRead() {
      return isAuthenticated();
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // ============= REGLAS DE COLECCIONES EXISTENTES =============

    match /users/{userId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
                       request.auth.uid == userId &&
                       hasRequiredFields(['email', 'firstName', 'lastName', 'role']);
      allow update: if (isAuthenticated() && request.auth.uid == userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /configuracion/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /sessions/{sessionId} {
      allow create, read, update, delete: if isAuthenticated() &&
                                             (request.resource.data.userId == request.auth.uid ||
                                              resource.data.userId == request.auth.uid);
    }

    match /notifications/{notifId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /role_permissions/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /estadisticas/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ============= REGLAS DE COLECCIONES DEL NEGOCIO =============

    // Contactos (clientes y proveedores)
    match /contactos/{docId} {
      allow read: if canRead();
      allow create, update: if canManageComercio();
      allow delete: if isAdmin();
    }

    // Inventario de pescados
    match /inventario/{docId} {
      allow read: if canRead();
      allow create, update: if canManageBodega();
      allow delete: if isAdmin();
    }

    // Ajustes de inventario (log de movimientos)
    match /ajustes-inventario/{docId} {
      allow read: if canRead();
      allow create: if canManageBodega();
      allow update, delete: if isAdmin();
    }

    // Insumos (hielo, pita, sal, etc.)
    match /insumos/{docId} {
      allow read: if canRead();
      allow create, update: if canManageBodega();
      allow delete: if isAdmin();
    }

    // Compras a proveedores
    match /compras/{docId} {
      allow read: if canRead();
      allow create: if canManageBodega() || canManageComercio();
      allow update: if canManageBodega() || canManageComercio();
      allow delete: if isAdmin();
    }

    // Abonos de compras
    match /abonos-compras/{docId} {
      allow read: if canRead();
      allow create: if canManageComercio();
      allow update, delete: if isAdmin();
    }

    // Ventas a clientes
    match /ventas/{docId} {
      allow read: if canRead();
      allow create: if canManageComercio();
      allow update: if canManageComercio() || canManageLogistica();
      allow delete: if isAdmin();
    }

    // Abonos de ventas
    match /abonos-ventas/{docId} {
      allow read: if canRead();
      allow create: if canManageComercio();
      allow update, delete: if isAdmin();
    }

    // Cavas (neveras reutilizables)
    match /cavas/{docId} {
      allow read: if canRead();
      allow create, update: if isAuthenticated() &&
                               userRole() in ['PROPIETARIO', 'ADMINISTRADOR', 'BODEGA', 'CHOFER'];
      allow delete: if isAdmin();
    }

    // Canastillas
    match /canastillas/{docId} {
      allow read: if canRead();
      allow create, update: if canManageBodega();
      allow delete: if isAdmin();
    }

    // Préstamos
    match /prestamos/{docId} {
      allow read: if canRead();
      allow create, update: if isAuthenticated() &&
                               userRole() in ['PROPIETARIO', 'ADMINISTRADOR'];
      allow delete: if isAdmin();
    }

    // Abonos de préstamos
    match /abonos-prestamos/{docId} {
      allow read: if canRead();
      allow create: if isAuthenticated() &&
                       userRole() in ['PROPIETARIO', 'ADMINISTRADOR'];
      allow update, delete: if isAdmin();
    }

    // Viajes de reparto
    match /viajes/{docId} {
      allow read: if canRead();
      allow create: if isAuthenticated() &&
                       userRole() in ['PROPIETARIO', 'ADMINISTRADOR', 'SECRETARIO'];
      allow update: if canManageLogistica() || canManageComercio();
      allow delete: if isAdmin();
    }

    // Camiones de la flota
    match /camiones/{docId} {
      allow read: if canRead();
      allow create, update: if isAuthenticated() &&
                               userRole() in ['PROPIETARIO', 'ADMINISTRADOR'];
      allow delete: if isAdmin();
    }

    // Nómina diaria de bodega
    match /nominas/{docId} {
      allow read: if isAuthenticated() &&
                     userRole() in ['PROPIETARIO', 'ADMINISTRADOR'];
      allow create: if isAuthenticated() &&
                       userRole() in ['PROPIETARIO', 'ADMINISTRADOR'];
      allow update, delete: if isAdmin();
    }

    // Alertas del sistema
    match /alertas/{docId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }
  }
}
