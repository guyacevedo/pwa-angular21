{
  "name": "pwa-angular21",
  "version": "0.0.0",
  "author": "Guy Acevedo – CTO Comercializadora Neymar",
  "homepage": "https://app.comercializadora-neymar.com",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:host": "ng serve --host 0.0.0.0",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:watch": "ng test --watch",
    "serve:ssr:pwa-angular21": "node dist/pwa-angular21/server/server.mjs",
    "prepare": "husky",
    "lint": "ng lint",
    "prebuild": "node scripts/generate-sw.js",
    "prestart": "node scripts/generate-sw.js"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "dependencies": {
    "@angular/animations": "21.0.8",
    "@angular/aria": "^21.1.5",
    "@angular/cdk": "^21.1.5",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-server": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@angular/service-worker": "^21.1.1",
    "@angular/ssr": "^21.0.5",
    "chart.js": "^4.5.1",
    "compression": "^1.8.1",
    "express": "^5.1.0",
    "firebase": "^12.7.0",
    "helmet": "^8.1.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "ng2-charts": "^8.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.0.5",
    "@angular-eslint/builder": "21.1.0",
    "@angular/build": "^21.0.5",
    "@angular/cli": "^21.0.5",
    "@angular/compiler-cli": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.8",
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "angular-eslint": "21.1.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jsdom": "^27.1.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.47.0",
    "vitest": "^4.0.8"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{html,scss,json,md}": [
      "prettier --write"
    ]
  },
  "description": "App de gestión pesquera hecha con Angular 21"
}
